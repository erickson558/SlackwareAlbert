#!/usr/bin/env sh
set -e

if command -v node >/dev/null 2>&1; then
  node scripts/enforce-version-commit.js
  exit 0
fi

if command -v pwsh >/dev/null 2>&1; then
  pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/enforce-version-commit.ps1
  exit 0
fi

if command -v powershell >/dev/null 2>&1; then
  powershell -NoProfile -ExecutionPolicy Bypass -File scripts/enforce-version-commit.ps1
  exit 0
fi

echo "[version-guard] No se encontró Node ni PowerShell para validar versión."
exit 1
