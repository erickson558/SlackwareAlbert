{
  "name": "slackwarealbert",
  "version": "1.1.1",
  "private": true,
  "description": "Aplicación de chat estilo Slack en PHP con separación backend/frontend",
  "scripts": {
    "build": "node scripts/build.js",
    "version:patch": "node scripts/version.js patch",
